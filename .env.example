##############################################################
# LE NIUM POS — Environment Configuration
# Copy this file: cp .env.example .env
# Then run: php artisan key:generate
##############################################################

APP_NAME="Le Nium POS"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

##############################################################
# DATABASE — XAMPP default (no password)
# For XAMPP: DB_HOST=127.0.0.1, DB_USERNAME=root, DB_PASSWORD=
##############################################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lenium_pos
DB_USERNAME=root
DB_PASSWORD=

##############################################################
# CACHE / SESSION / QUEUE
##############################################################
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
FILESYSTEM_DISK=local

##############################################################
# MAIL
##############################################################
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@leniumpos.com"
MAIL_FROM_NAME="${APP_NAME}"

##############################################################
# M-PESA DARAJA — developer.safaricom.co.ke
##############################################################
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL="${APP_URL}/webhooks/mpesa/callback"
MPESA_SANDBOX=true

##############################################################
# AFRICA'S TALKING (SMS) — africastalking.com
##############################################################
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=LeNiumPOS

##############################################################
# WHATSAPP BUSINESS API
##############################################################
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

##############################################################
# AIRTEL MONEY
##############################################################
AIRTEL_API_KEY=
AIRTEL_CLIENT_SECRET=
AIRTEL_SANDBOX=true

##############################################################
# PESAPAL (Card payments) — pesapal.com
##############################################################
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_SANDBOX=true

##############################################################
# DEEPSEEK (Leumas AI)
##############################################################
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

##############################################################
# PLATFORM
##############################################################
SUPER_ADMIN_EMAIL=samuel@leniumpos.com
SUPPORT_EMAIL=support@leniumpos.com

VITE_APP_NAME="${APP_NAME}"
